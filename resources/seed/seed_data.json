  },
  "settings": {
    "language": "fr",
    "theme": "light",
    "numerotation.facture.prefixe":          "F{ANNEE}-",
    "numerotation.facture.prochain":         "1",
    "numerotation.facture.longueur":         "4",
    "numerotation.facture.reset_annuel":     "true",
    "numerotation.facture.dernier_annee":    "2026",
    "numerotation.dossier.prefixe":          "REP-",
    "numerotation.dossier.prochain":         "1",
    "numerotation.dossier.longueur":         "4",
    "numerotation.dossier.reset_annuel":     "false",
    "numerotation.dossier.dernier_annee":    "2026",
    "numerotation.bon_travail.prefixe":      "BT{ANNEE}/",
    "numerotation.bon_travail.prochain":     "1",
    "numerotation.bon_travail.longueur":     "4",
    "numerotation.bon_travail.reset_annuel": "true",
    "numerotation.bon_travail.dernier_annee": "2026",
    "numerotation.facture_achat.prefixe":    "FA-",
    "numerotation.facture_achat.prochain":   "1",
    "numerotation.facture_achat.longueur":   "4",
    "numerotation.facture_achat.reset_annuel": "false",
    "numerotation.facture_achat.dernier_annee": "2026",
    "sidebar.compact":                       "false",
    "app.locale":                            "fr",
    "app.numerals":                          "western"
  },
  "report_templates": [
    {
      "name": "invoice_v1",
      "category": "facturation",
      "body": {
        "templateId": "invoice_v1",
        "title": {"fr": "Facture", "en": "Invoice"},
        "paperSize": "A4",
        "orientation": "portrait",
        "bands": [
          {
            "type": "header",
            "height": 60,
            "elements": [
              {"type": "image",  "x": 10, "y": 5,  "w": 80, "h": 40, "value": "{logo}"},
              {"type": "text",   "x": 200, "y": 5, "w": 100, "h": 20, "value": "FACTURE", "font_size": 18, "bold": true, "align": "right"},
              {"type": "field",  "x": 200, "y": 28, "w": 100, "h": 14, "value": "N° {numero}", "align": "right"},
              {"type": "field",  "x": 200, "y": 42, "w": 100, "h": 14, "value": "Date : {date_emission}", "align": "right"}
            ]
          },
          {
            "type": "detail",
            "height": 18,
            "datasource": "lignes",
            "elements": [
              {"type": "field", "x": 10,  "y": 2, "w": 220, "h": 14, "value": "{designation}"},
              {"type": "field", "x": 230, "y": 2, "w": 30,  "h": 14, "value": "{quantite}", "align": "center"},
              {"type": "field", "x": 260, "y": 2, "w": 40,  "h": 14, "value": "{prix_unitaire}", "align": "right"},
              {"type": "field", "x": 300, "y": 2, "w": 45,  "h": 14, "value": "{montant}",       "align": "right"}
            ]
          },
          {
            "type": "footer",
            "height": 50,
            "elements": [
              {"type": "line",  "x": 10, "y": 5,  "w": 290, "h": 1},
              {"type": "field", "x": 250, "y": 10, "w": 50, "h": 14, "value": "HT : {montant_ht}", "align": "right"},
              {"type": "field", "x": 250, "y": 24, "w": 50, "h": 14, "value": "TVA : {montant_tva}", "align": "right"},
              {"type": "field", "x": 240, "y": 38, "w": 60, "h": 14, "value": "TTC : {montant_ttc}", "bold": true, "align": "right"}
            ]
          }
        ]
      }
    },
    {
      "name": "bon_reception_v1",
      "category": "reception",
      "body": {
        "templateId": "bon_reception_v1",
        "title": {"fr": "Bon de Réception", "en": "Reception Form"},
        "paperSize": "A4",
        "orientation": "portrait",
        "bands": [
          {
            "type": "header",
            "height": 80,
            "elements": [
              {"type": "text",  "x": 10, "y": 5,  "w": 290, "h": 24, "value": "BON DE RÉCEPTION VÉHICULE", "font_size": 16, "bold": true, "align": "center"},
              {"type": "field", "x": 10, "y": 35, "w": 140, "h": 14, "value": "Client : {client_nom}"},
              {"type": "field", "x": 10, "y": 52, "w": 140, "h": 14, "value": "Véhicule : {vehicule}"},
              {"type": "field", "x": 160, "y": 35, "w": 140, "h": 14, "value": "Date : {date_depot}", "align": "right"},
              {"type": "field", "x": 160, "y": 52, "w": 140, "h": 14, "value": "Kilométrage : {kilometrage}", "align": "right"}
            ]
          },
          {
            "type": "footer",
            "height": 60,
            "elements": [
              {"type": "text", "x": 10,  "y": 20, "w": 120, "h": 14, "value": "Signature client :"},
              {"type": "text", "x": 180, "y": 20, "w": 120, "h": 14, "value": "Signature réceptionniste :"}
            ]
          }
        ]
      }
    }
  ]
}
